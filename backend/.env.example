# Backend secrets — copy to backend/.env (gitignored) and fill in.
# All are OPTIONAL: a missing key degrades that section of the payload to an
# {"error": "..."} envelope rather than failing the whole request.

# NOAA Climate Data Online token
NOAA_TOKEN=

# U.S. Energy Information Administration API key
EIA_API_KEY=

# NREL (solar / PVWatts). Defaults to the public "DEMO_KEY" if unset (rate-limited).
NREL_API_KEY=DEMO_KEY

# World Air Quality Index token
WAQI_TOKEN=

# ATTOM property-data API key
ATTOM_API_KEY=

# FRED (house price index) API key
FRED_API_KEY=

# Outbound HTTP timeout (seconds) for external data sources.
REQUEST_TIMEOUT_SECONDS=10

# Comma-separated origins allowed to call this API (the Next.js proxy).
ALLOWED_ORIGINS=http://localhost:3000
