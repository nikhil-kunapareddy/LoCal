# --- Public (browser-exposed) — use only non-secrets here ---
# Where the browser sends API calls. Leave unset to use same-origin Next.js
# routes (recommended), which proxy server-side to the FastAPI backend.
# NEXT_PUBLIC_API_BASE=https://api.yourdomain.com

# --- Server-only (NOT exposed to the browser) ---
# Base URL of the FastAPI backend that the Next.js /api/* routes proxy to.
# Defaults to http://localhost:8000 if unset.
BACKEND_API_BASE=http://localhost:8000
